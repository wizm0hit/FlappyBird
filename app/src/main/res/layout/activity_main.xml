<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mainMenuLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background_day">

    <ImageView
        android:id="@+id/logoMessage"
        android:layout_width="260dp"
        android:layout_height="260dp"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="36dp"
        android:src="@drawable/message" />

    <TextView
        android:id="@+id/tvHighScore"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/logoMessage"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="4dp"
        android:fontFamily="@font/pixeloperator"
        android:letterSpacing="0.08"
        android:shadowColor="#000000"
        android:shadowDx="2"
        android:shadowDy="2"
        android:shadowRadius="2"
        android:text="HIGHEST SCORE: 0"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold" />

    <LinearLayout
        android:id="@+id/themeContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/tvHighScore"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="16dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/pixeloperator"
            android:text="LIGHT MODE"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:shadowColor="#000000"
            android:shadowDx="2"
            android:shadowDy="2"
            android:shadowRadius="1" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switchTheme"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:thumb="@drawable/switch_thumb"
            android:track="@drawable/switch_track"
            app:thumbTint="@null"
            app:trackTint="@null" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/pixeloperator"
            android:text="DARK MODE"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:shadowColor="#000000"
            android:shadowDx="2"
            android:shadowDy="2"
            android:shadowRadius="1" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/birdSelectionContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/themeContainer"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="32dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnPrevBird"
            android:layout_width="58dp"
            android:layout_height="58dp"
            android:background="@drawable/oval_button"
            android:backgroundTint="@null"
            android:gravity="center"
            android:padding="0dp"
            android:text="◀"
            android:textColor="#3B2000"
            android:textSize="16sp" />

        <ImageView
            android:id="@+id/imgBirdPreview"
            android:layout_width="96dp"
            android:layout_height="72dp"
            android:layout_marginHorizontal="24dp"
            android:scaleType="fitCenter"
            android:src="@drawable/yellowbird_midflap" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnNextBird"
            android:layout_width="58dp"
            android:layout_height="58dp"
            android:background="@drawable/oval_button"
            android:backgroundTint="@null"
            android:gravity="center"
            android:padding="0dp"
            android:text="▶"
            android:textColor="#3B2000"
            android:textSize="16sp" />

    </LinearLayout>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnPlay"
        android:layout_width="230dp"
        android:layout_height="60dp"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="64dp"
        android:background="@drawable/play_button"
        android:backgroundTint="@null"
        android:fontFamily="@font/pixeloperatorbold"
        android:letterSpacing="0.08"
        android:text="▶ PLAY"
        android:textColor="#3B2000"
        android:textSize="24sp"
        android:textStyle="bold"
        tools:ignore="HardcodedText" />

</RelativeLayout>